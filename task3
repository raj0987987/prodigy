import argparse
import sys
import unittest
import string
import getpass

def check_password_strength(password: str) -> dict:
    """
    Assesses the complexity of a password and returns its strength score,
    classification label, and detailed feedback.
    
    Args:
        password (str): The password string to evaluate.
        
    Returns:
        dict: A dictionary containing:
            - 'score': Numeric score (0-6)
            - 'rating': Strength classification ('Weak', 'Medium', 'Strong', 'Very Strong')
            - 'feedback': List of strings indicating missing complexity requirements
    """
    score = 0
    feedback = []
    
    # Criteria flags
    has_lower = any(c.islower() for c in password)
    has_upper = any(c.isupper() for c in password)
    has_digit = any(c.isdigit() for c in password)
    has_special = any(c in string.punctuation for c in password)
    length = len(password)
    
    # 1. Length evaluation
    if length >= 12:
        score += 2
    elif length >= 8:
        score += 1
    else:
        feedback.append("Password is too short (minimum 8 characters required, 12+ recommended).")
        
    # 2. Diversity evaluation
    if has_lower:
        score += 1
    else:
        feedback.append("Add lowercase letters (a-z).")
        
    if has_upper:
        score += 1
    else:
        feedback.append("Add uppercase letters (A-Z).")
        
    if has_digit:
        score += 1
    else:
        feedback.append("Add numbers (0-9).")
        
    if has_special:
        score += 1
    else:
        feedback.append("Add special characters (e.g., !, @, #, $, %, etc.).")
        
    # Classification based on score and critical rules
    # If the password is less than 8 characters, force it to 'Weak' regardless of diversity points
    if length < 8:
        rating = "Weak"
    elif score <= 2:
        rating = "Weak"
    elif score <= 4:
        rating = "Medium"
    elif score == 5:
        rating = "Strong"
    else:
        rating = "Very Strong"
        
    return {
        "score": score,
        "rating": rating,
        "feedback": feedback
    }

def interactive_mode():
    print("========================================")
    print("      Password Complexity Checker       ")
    print("========================================")
    while True:
        choice = input("Do you want to check a password (c) or quit (q)? ").lower().strip()
        if choice in ('q', 'quit', 'exit'):
            print("Goodbye!")
            break
        elif choice not in ('c', 'check'):
            print("Invalid choice. Please enter 'c' or 'q'.")
            continue
            
        # Use getpass to securely hide password entry, but fall back to input if getpass fails/warns
        try:
            password = getpass.getpass("Enter password to evaluate (input will be hidden): ")
        except Exception:
            password = input("Enter password to evaluate: ")
            
        if not password:
            print("Password cannot be empty!")
            continue
            
        result = check_password_strength(password)
        
        print("\n" + "-" * 40)
        print(f"Rating:   {result['rating']}")
        print(f"Score:    {result['score']}/6")
        
        if result['feedback']:
            print("\nSuggestions to improve strength:")
            for item in result['feedback']:
                print(f" - {item}")
        else:
            print("\nExcellent! Your password meets all security requirements.")
        print("-" * 40 + "\n")

# Built-in unit tests to verify the scoring and feedback
class TestPasswordChecker(unittest.TestCase):
    def test_weak_passwords(self):
        # Short passwords
        res1 = check_password_strength("abc")
        self.assertEqual(res1['rating'], "Weak")
        self.assertIn("Password is too short (minimum 8 characters required, 12+ recommended).", res1['feedback'])
        
        # Long but simple character classes
        res2 = check_password_strength("abcdefghijkl")
        self.assertEqual(res2['rating'], "Weak")  # Length 12+ (+2), but only lowercase (+1) = score 3, but missing digit, upper, special feedback
        
    def test_medium_passwords(self):
        res = check_password_strength("Abcdefgh")  # Length 8 (+1), Lower (+1), Upper (+1) = 3
        self.assertEqual(res['rating'], "Medium")
        
    def test_strong_passwords(self):
        res = check_password_strength("Abcdefgh1")  # Length 8 (+1), Lower (+1), Upper (+1), Digit (+1) = 4 points.
        # Length 12 (+2), Lower (+1), Upper (+1), Digit (+1) = 5
        res = check_password_strength("Abcdefghijkl1")
        self.assertEqual(res['rating'], "Strong")
        
    def test_very_strong_passwords(self):
        # Length 12 (+2), Lower (+1), Upper (+1), Digit (+1), Special (+1) = 6
        res = check_password_strength("Abcdefghijkl1!")
        self.assertEqual(res['rating'], "Very Strong")
        self.assertEqual(len(res['feedback']), 0)

def main():
    parser = argparse.ArgumentParser(description="Password Complexity Checker.")
    parser.add_argument('-p', '--password', help="The password string to evaluate directly")
    parser.add_argument('-i', '--interactive', action='store_true', help="Run in interactive mode")
    parser.add_argument('--test', action='store_true', help="Run built-in unit tests")
    
    args = parser.parse_args()
    
    if args.test:
        suite = unittest.TestLoader().loadTestsFromTestCase(TestPasswordChecker)
        runner = unittest.TextTestRunner(verbosity=2)
        result = runner.run(suite)
        sys.exit(0 if result.wasSuccessful() else 1)
        
    if args.interactive or (args.password is None):
        interactive_mode()
    else:
        result = check_password_strength(args.password)
        print(f"Rating: {result['rating']} (Score: {result['score']}/6)")
        if result['feedback']:
            print("Suggestions:")
            for item in result['feedback']:
                print(f" - {item}")

if __name__ == "__main__":
    main()
