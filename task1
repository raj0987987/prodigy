import argparse
import unittest
import sys

def caesar_cipher(text: str, shift: int, mode: str) -> str:
    """
    Encrypts or decrypts text using the Caesar Cipher algorithm.
    
    Args:
        text (str): The input text to process.
        shift (int): The number of positions to shift each character.
        mode (str): Either 'encrypt' or 'decrypt'.
        
    Returns:
        str: The resulting encrypted or decrypted text.
    """
    if mode == 'decrypt':
        shift = -shift
        
    result = []
    for char in text:
        if char.isalpha():
            # Determine ASCII base (65 for uppercase, 97 for lowercase)
            start = 65 if char.isupper() else 97
            # Shift within 0-25 range and convert back to char
            shifted_char = chr((ord(char) - start + shift) % 26 + start)
            result.append(shifted_char)
        else:
            result.append(char)
            
    return "".join(result)

def interactive_mode():
    print("========================================")
    print("          Caesar Cipher Tool            ")
    print("========================================")
    while True:
        choice = input("Do you want to (e)ncrypt, (d)ecrypt, or (q)uit? ").lower().strip()
        if choice in ('q', 'quit', 'exit'):
            print("Goodbye!")
            break
        elif choice not in ('e', 'encrypt', 'd', 'decrypt'):
            print("Invalid choice. Please enter 'e', 'd', or 'q'.")
            continue
            
        mode = 'encrypt' if choice in ('e', 'encrypt') else 'decrypt'
        message = input("Enter the message: ")
        
        while True:
            try:
                shift = int(input("Enter shift value (integer): "))
                break
            except ValueError:
                print("Please enter a valid integer for the shift value.")
                
        result = caesar_cipher(message, shift, mode)
        print("-" * 40)
        print(f"Original:  {message}")
        print(f"Result:    {result}")
        print("-" * 40)
        print()

# Built-in unit tests for testing logic
class TestCaesarCipher(unittest.TestCase):
    def test_cipher(self):
        self.assertEqual(caesar_cipher("abc", 3, "encrypt"), "def")
        self.assertEqual(caesar_cipher("def", 3, "decrypt"), "abc")
        self.assertEqual(caesar_cipher("ABC", 3, "encrypt"), "DEF")
        self.assertEqual(caesar_cipher("Hello, World! 123", 5, "encrypt"), "Mjqqt, Btwqi! 123")
        self.assertEqual(caesar_cipher("Mjqqt, Btwqi! 123", 5, "decrypt"), "Hello, World! 123")
        self.assertEqual(caesar_cipher("abc", 29, "encrypt"), "def")
        self.assertEqual(caesar_cipher("abc", -3, "encrypt"), "xyz")

def main():
    parser = argparse.ArgumentParser(description="Encrypt or decrypt text using Caesar Cipher.")
    parser.add_argument('-m', '--mode', choices=['encrypt', 'decrypt'], help="Mode: encrypt or decrypt")
    parser.add_argument('-t', '--text', help="The message text to process")
    parser.add_argument('-s', '--shift', type=int, help="The shift value (integer)")
    parser.add_argument('-i', '--interactive', action='store_true', help="Run in interactive mode")
    parser.add_argument('--test', action='store_true', help="Run built-in unit tests")
    
    args = parser.parse_args()
    
    if args.test:
        suite = unittest.TestLoader().loadTestsFromTestCase(TestCaesarCipher)
        runner = unittest.TextTestRunner(verbosity=2)
        result = runner.run(suite)
        sys.exit(0 if result.wasSuccessful() else 1)
        
    if args.interactive or (args.mode is None and args.text is None and args.shift is None):
        interactive_mode()
    else:
        if args.mode is None or args.text is None or args.shift is None:
            parser.error("All of --mode, --text, and --shift must be provided when not running interactively.")
        result = caesar_cipher(args.text, args.shift, args.mode)
        print(result)

if __name__ == "__main__":
    main()
